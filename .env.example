# FinDash Frontend Environment Variables
# Copy this file to .env and fill in your values.

# Django backend URL (defaults to localhost:8000 in development)
# In production, set this to your deployed API domain e.g. https://api.findash.com
VITE_BACKEND_URL=http://localhost:8000

# Massive.com Stock API key (for live market data)
# Get your key at https://massive.com/dashboard
# Leave blank to run in mock/demo mode
VITE_MASSIVE_API_KEY=
